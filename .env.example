# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (optional, for admin tasks / migrations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (for invite links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron job secret (for /api/cron/reminders)
CRON_SECRET=your-cron-secret

# LINE Messaging API (optional — Phase 3)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Commercial launch controls (optional — Phase 7)
LAUNCH_INVITE_REQUIRED=false
